# 香港 AI 网关环境变量示例
# 复制为 .env 后填入真实值

APP_HOST=0.0.0.0
APP_PORT=9000

# 与国内服务约定一致的内部密钥
INTERNAL_SECRET=请替换为与国内服务一致的强随机字符串

# OpenAI (留空 base_url 则直连 OpenAI；使用中转站时填中转地址)
OPENAI_API_KEY=sk-填入你的key
OPENAI_BASE_URL=
# Responses API 多模态对话模型(由其通过 image_generation 工具生图): gpt-4.1 / gpt-4o
OPENAI_MODEL=gpt-4.1
# image_generation 工具使用的图像模型: gpt-image-1 / gpt-image-2
OPENAI_IMAGE_MODEL=gpt-image-1
# 生成图片尺寸: 1024x1024 / 1536x1024 / 1024x1536 / auto
OPENAI_IMAGE_SIZE=1024x1024

# 模拟生成开关：true 时不调用 OpenAI，等待 10s 后直接返回原图（省钱测试用）
MOCK_GENERATE=false

# 图片存储根目录
STORAGE_DIR=/storage

# Codex 会话功能（Web 端 codex 对话）
# 首次使用前需在本机执行: codex login   （用 ChatGPT 账号登录，SDK 自动复用会话）
# 留空则使用 SDK 默认模型；可填 gpt-5.4 等
CODEX_MODEL=
CODEX_REASONING_EFFORT=high

# Codex 出站代理（用代理访问 OpenAI 时填，留空直连）
# 仅作用于 codex 子进程，不影响 OpenAI 图片生成路径
# 例如本机 clash/v2ray: http://127.0.0.1:8080
CODEX_PROXY=
