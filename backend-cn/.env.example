# 国内主后端环境变量示例
# 复制为 .env 后填入真实值

# 服务监听
APP_HOST=0.0.0.0
APP_PORT=8000

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=aiprovider

# JWT
JWT_SECRET=请替换为强随机字符串
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# 积分参数(可配置)
INITIAL_CREDITS=20
COST_PER_IMAGE=1

# 香港 AI 网关
HK_BASE_URL=http://127.0.0.1:9000
HK_INTERNAL_SECRET=请替换为与香港服务一致的强随机字符串
HK_TIMEOUT_SECONDS=120

# 上传限制
MAX_UPLOAD_MB=10

# CORS 允许的前端来源(逗号分隔)
CORS_ORIGINS=http://localhost:5173
