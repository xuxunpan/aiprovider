[Unit]
Description=AI Provider Backend CN
After=network.target mongod.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/aiprovider/backend-cn
EnvironmentFile=/opt/aiprovider/backend-cn/.env
ExecStart=/opt/aiprovider/backend-cn/.venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
